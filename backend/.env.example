# Salin file ini menjadi ".env" sebelum menjalankan server

# Port server
PORT=4000

# Rahasia untuk menandatangani JWT access & refresh token.
# WAJIB diganti dengan string acak yang panjang (minimal 32 karakter) sebelum produksi.
# Contoh membuat secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=ganti_dengan_secret_acak_yang_panjang_dan_unik
JWT_REFRESH_SECRET=ganti_dengan_secret_acak_lain_yang_berbeda

# Masa berlaku token
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Lokasi file database SQLite (dibuat otomatis jika belum ada)
DB_FILE=./data/sitas.db

# Origin frontend yang diizinkan mengakses API (CORS)
CORS_ORIGIN=http://localhost:5173

# Jumlah salt round bcrypt (10-12 direkomendasikan untuk produksi)
BCRYPT_SALT_ROUNDS=12
